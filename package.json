{
  "name": "hedgemont-frontend",
  "private": true,
  "type": "module",
  "scripts": {
    "sass:build": "sass --quiet-deps --silence-deprecation=import --load-path=node_modules app/styles/sass/app.scss app/styles/app.css",
    "sass:watch": "sass --quiet-deps --silence-deprecation=import --load-path=node_modules --watch app/styles/sass/app.scss app/styles/app.css",
    "build": "npm run sass:build && react-router build",
    "dev": "npm run sass:watch & react-router dev",
    "dev-win": "concurrently \"npm run sass:watch\" \"react-router dev\"",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc"
  },
  "dependencies": {
    "@emailjs/browser": "^4.4.1",
    "@react-router/node": "7.12.0",
    "@react-router/serve": "7.12.0",
    "bootstrap": "^5.3.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "embla-carousel": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "isbot": "^5.1.31",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "7.12.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@epic-web/config": "^1.24.1",
    "@react-router/dev": "7.12.0",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^22",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.3",
    "eslint-plugin-i18next": "^6.1.3",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "sass-embedded": "^1.97.3",
    "tailwindcss": "^4.2.1",
    "tailwindcss-motion": "^1.1.1",
    "typescript": "^5.9.2",
    "vite": "^7.1.7",
    "vite-tsconfig-paths": "^5.1.4"
  }
}
